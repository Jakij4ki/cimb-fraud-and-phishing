# Database Configuration
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cimb_phishing_db

# Security Configuration
# Generate a secure string for production (e.g. `openssl rand -hex 32`)
SECRET_KEY=supersecretkey_change_me_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# Server Configuration
# List of origins allowed for CORS
CORS_ORIGINS=["http://localhost:3000"]
# Set to 'production' in production
ENVIRONMENT=development
# Max request size in megabytes
MAX_REQUEST_SIZE_MB=1

# Admin Settings
# Default password for the first admin user created
ADMIN_DEFAULT_PASSWORD=changeme123

# ML Model
# Path to the fine-tuned IndoBERT model
ML_MODEL_PATH=./ml/model

# Rate Limits
RATE_LIMIT_ANALYZE=10/minute
RATE_LIMIT_REPORT=5/minute
RATE_LIMIT_LOGIN=5/minute
